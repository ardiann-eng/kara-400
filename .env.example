# ═══════════════════════════════════════════════════════
# KARA Bot — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════

# === MODE & EXECUTION ===
# Data source: "mainnet" = real prices, "testnet" = fake prices
KARA_DATA_SOURCE=mainnet

# Trade mode: "paper" = simulated, "live" = real money (careful!)
KARA_TRADE_MODE=paper

KARA_FULL_AUTO=false               # "true" | "false" — enable full-auto mode?
KARA_EXECUTION_EXCHANGE=bybit       # fixed: Hyperliquid is market data only

# === BYBIT EXECUTION ===
# Keep testnet=true until testnet lifecycle audit passes.
BYBIT_TESTNET=true
BYBIT_TESTNET_ONLY=true              # keep true until mainnet rollout audit
BYBIT_ACCOUNT_TYPE=UNIFIED
BYBIT_CATEGORY=linear
BYBIT_SETTLE_COIN=USDT
BYBIT_RECV_WINDOW=5000
BYBIT_MAX_PRICE_GAP_PCT=0.003
BYBIT_MAX_SLIPPAGE_PCT=0.002
# Live-only hard ceilings aligned with current scalper/user settings.
BYBIT_LIVE_ASSET_ALLOWLIST=BTC,ETH
BYBIT_LIVE_MAX_LEVERAGE=20
BYBIT_LIVE_MAX_POSITIONS=3
BYBIT_LIVE_MAX_RISK_PER_TRADE_PCT=0.035
BYBIT_LIVE_MAX_TOTAL_RISK_PCT=0.105
BYBIT_LIVE_MAX_SYMBOL_NOTIONAL_PCT=7.0
BYBIT_LIVE_MAX_TOTAL_NOTIONAL_PCT=21.0
BYBIT_LIVE_MAX_SIGNAL_AGE_S=30
BYBIT_LIVE_MAX_QUOTE_AGE_S=5
BYBIT_LIVE_MAX_SPREAD_PCT=0.0015
BYBIT_LIVE_MIN_DEPTH_RATIO=1.0
# Required only for real Bybit mainnet:
# BYBIT_MAINNET_ACK=I_UNDERSTAND_BYBIT_MAINNET_RISK

# === HYPERLIQUID CREDENTIALS ===
# Generate at: https://app.hyperliquid.xyz (Testnet/Mainnet)
# KEEP PRIVATE KEY SAFE!
HL_WALLET_ADDRESS=0x...            # Your wallet address
HL_PRIVATE_KEY=0x...               # Your private key (NEVER share!)

# === TELEGRAM BOT (for notifications) ===
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=CHANGEME                # Bot token from @BotFather
TELEGRAM_CHAT_ID=123456789                 # Your personal chat ID (Legacy, use ALLOWED_CHAT_IDS)
ALLOWED_CHAT_IDS=123456789,987654321       # Comma-separated list of allowed user IDs

# === DASHBOARD ===
DASHBOARD_HOST=0.0.0.0             # Listen on all interfaces
DASHBOARD_PORT=8000                # Web dashboard port
SECRET_KEY=CHANGEME                # JWT/session secret. MUST BE CHANGED IN PRODUCTION!

# === SECURITY ===
FERNET_KEY=                        # Generate using cryptography.fernet.Fernet.generate_key()

# === DATABASE ===
# ⚠️  PENTING: Jangan set DB_PATH=kara_data.db (relative path)!
# Ini menyebabkan split-storage bug di Railway:
#   users.json  → /app/storage/users.json  (di volume) → balance survive ✓
#   kara_data.db → /app/kara_data.db       (di luar volume) → posisi/journal reset ✗
#
# LOCAL (Windows):
#   DB_PATH=data/kara_data.db
#
# RAILWAY: Hapus baris DB_PATH atau set ke path absolut:
#   DB_PATH=/app/storage/kara_data.db
#   STORAGE_DIR=/app/storage
#
# Rekomendasi: kosongkan saja, biarkan config.py pilih path yang benar otomatis.
# DB_PATH=                          # Biarkan kosong = auto (pakai STORAGE_DIR/kara_data.db)
REDIS_URL=                         # Optional: redis://localhost:6379

# === STORAGE (Railway) ===
# Set ini di Railway Variables! Jangan diset untuk lokal (auto-detect).
# STORAGE_DIR=/app/storage          # ← uncomment dan isi untuk Railway

# === LOGGING ===
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_FILE=kara.log                  # Log file path

# === WEEKLY AI AUDIT (Monday 06:00 UTC) ===
# OpenAI-compatible gateway — advisory only; never in trade hot path.
KARA_REVIEW_API_KEY=
KARA_REVIEW_BASE_URL=https://api.ojwgeoubcweojfb.shop/v1
KARA_REVIEW_MODEL=mimo/mimo-v2.5-pro
KARA_REVIEW_MODELS=mimo/mimo-v2.5-pro,mimo-v2.5-pro
KARA_REVIEW_ENABLED=true
KARA_REVIEW_LOOKBACK_DAYS=7
KARA_REVIEW_BASELINE_DAYS=30
KARA_REVIEW_MIN_SAMPLES=30
KARA_REVIEW_HOUR_UTC=6
# Aliases (optional)
MIMO_API_KEY=
MIMO_BASE_URL=https://api.ojwgeoubcweojfb.shop/v1
MIMO_MODEL=mimo/mimo-v2.5-pro

# ═══════════════════════════════════════════════════════
# IMPORTANT SAFETY NOTES:
# ═══════════════════════════════════════════════════════
# 1. NEVER share your private key
# 2. Start with KARA_MODE=paper and small test amount
# 3. Verify bot signals carefully before enabling full-auto
# 4. Keep backups of your .env and database
# 5. Test on testnet first, then slowly increase to live
# ═══════════════════════════════════════════════════════
